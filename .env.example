# DroneRoute Configuration
PORT=3001
JWT_SECRET=change-this-to-a-random-secret
DB_PATH=./data/droneroute.db

# Self-hosted mode (default: true). Set to false for cloud deployments.
SELF_HOSTED=true

# Whether the session cookie is marked Secure (browser only sends it over
# HTTPS). Defaults to true when NODE_ENV=production (the standard
# docker-compose setup), false otherwise. Only set this if you're running a
# self-hosted instance on plain HTTP behind a proxy that doesn't set
# NODE_ENV, or on a local network with no TLS at all — leaving the default
# Secure=true in that case would silently break login (the cookie would
# never be sent back).
# COOKIE_SECURE=false

# Allowed cross-origin origins (comma-separated). Only needed when the frontend
# is served from a different origin than the API. Leave unset for the standard
# setup (the SPA is served same-origin), which disables cross-origin requests.
# CORS_ORIGIN=https://app.example.com,https://www.example.com

# Admin email — only used when SELF_HOSTED=false. The user with this email
# gets admin privileges and access to the back office panel.
# ADMIN_EMAIL=admin@example.com

# Mapbox access token (required for map rendering).
# Get yours at https://account.mapbox.com/access-tokens/
MAPBOX_TOKEN=your-mapbox-token-here

# Default map location shown when the app loads. Handy for self-hosted
# instances so the map opens on your local area instead of the default.
# Format: "lat,lng" or "lat,lng,zoom" (zoom is optional, defaults to 13).
# Ranges: lat -90..90, lng -180..180, zoom 0..22. Invalid values are ignored.
# DEFAULT_MAP_VIEW=41.3874,2.1686,13

# Base URL used to build password-reset links (e.g. https://skyroute.example.com).
# REQUIRED for password reset to work — deliberately never derived from the
# incoming request's Host header, since that's attacker-controlled and would
# let someone poison a reset email with a phishing link. Without this set,
# forgot-password still responds normally (no account-enumeration signal)
# but logs an error server-side instead of sending/relaying a link.
APP_URL=https://skyroute.example.com

# SMTP server for sending password-reset emails. If any of these are unset,
# forgot-password still works — the reset link is logged server-side for an
# operator to manually relay instead of emailed.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-username
# SMTP_PASSWORD=your-smtp-password
# SMTP_FROM=SkyRoute <no-reply@example.com>

# Sentry error tracking (backend). Unset = disabled, no cost. Get a DSN by
# creating a project at https://sentry.io (or a self-hosted Sentry instance).
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Sentry error tracking (frontend). Separate DSN/project from the backend one
# is recommended so client and server errors don't mix in one issue stream.
# Must be prefixed VITE_ to be included in the built frontend bundle.
# VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
